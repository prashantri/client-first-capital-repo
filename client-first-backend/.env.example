# Backend
MONGODB_URI=mongodb+srv://<username>:<password>@<cluster>.mongodb.net/client-first-capital?retryWrites=true&w=majority
JWT_SECRET=your-super-secret-jwt-key-change-in-production
JWT_EXPIRATION=7d
PORT=3000

# Gmail SMTP
# Use a Gmail App Password (not your regular password):
# Google Account → Security → 2-Step Verification → App Passwords
SMTP_USER=your-gmail@gmail.com
SMTP_PASS=your-gmail-app-password
# SMTP_FROM must match SMTP_USER — Gmail only sends from the authenticated account
SMTP_FROM=Client First Capital <your-gmail@gmail.com>
